/* Typography Setup */
@reference './globals.css';

h1 {
    @apply text-4xl font-bold mb-4;

}

h2 {
    @apply text-3xl font-semibold
}

h3 {
    @apply text-2xl font-medium
}

p {
    @apply text-base leading-relaxed mb-4;
}

a {
    @apply hover:underline;
}

ul {
    @apply list-inside;
}

code {
    @apply font-mono px-1 rounded;
}

table {
    @apply w-full border;
}

th,
td {
    @apply px-4 py-2 border;
}

/* Layout Helpers */
body {
    @apply bg-[var(--bg)]
}

.container {
    @apply w-full max-w-[1280px] mx-auto px-4;
}

.grid-layout {
    @apply grid grid-cols-1 md:grid-cols-12 gap-4;
}

.content-area {
    @apply col-span-full md:col-span-8 md:col-start-3;
}

.section {
    @apply mb-12 grid sm:grid-cols-5 md:grid-cols-7;
}

.section h2 {
    @apply mb-5 sm:mb-5 md:mb-0;
}

.navbar {
    left: 50%;
    transform: translateX(-50%);
    background: rgba(var(--accent-rgb), 0.19);
    background-color: var(--bg-rgba);
    color: var(--text);
    border: 1px solid rgba(var(--accent-rgb));
    /* frosted glass from From https://css.glass */
}

footer {
    /* background: rgba(var(--accent-rgb), 0.19); */
    background: var(--text);
    color: var(--bg);
    border-top: 1px solid rgba(var(--accent-rgb), 0.57);
    @apply py-3;
}

.boxShadow {
    box-shadow: 0px 0px 30px 2px rgba(var(--accent-rgb), 0.2);
}

i {
    font-size: 30px;
    max-width: max-content;
}

a:hover {
    @apply no-underline;
}

/* 🗂️ Horizontal Bento Cards for Themes */
.horizontal-bento-card {
    display: block;
    border-radius: 1.25rem;
    padding: 1.5rem;
    border: 1.5px solid rgba(var(--accent-rgb), 0.15);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    min-height: 145px;
    box-shadow: 0 4px 25px rgba(0, 0, 0, 0.05);
}

.horizontal-bento-card-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100%;
    height: 100%;
}

/* Scoped Theme Styles for individual cards */
.horizontal-bento-card.theme-charcoal {
    background-color: #1a1a1a;
    color: #e5e5e5;
    --accent: #0ea5e9;
    --accent-rgb: 14, 165, 233;
    border-color: rgba(14, 165, 233, 0.15);
}
.horizontal-bento-card.theme-charcoal:hover {
    border-color: #0ea5e9;
    box-shadow: 0 10px 35px -10px rgba(14, 165, 233, 0.45);
}

.horizontal-bento-card.theme-sunlight {
    background-color: #f3f0e6;
    color: #2c2a28;
    --accent: #c47f17;
    --accent-rgb: 196, 127, 23;
    border-color: rgba(196, 127, 23, 0.15);
}
.horizontal-bento-card.theme-sunlight:hover {
    border-color: #c47f17;
    box-shadow: 0 10px 35px -10px rgba(196, 127, 23, 0.45);
}

.horizontal-bento-card.theme-crimson {
    background-color: #1e0e14;
    color: #f5e9f0;
    --accent: #dc2626;
    --accent-rgb: 220, 38, 38;
    border-color: rgba(220, 38, 38, 0.15);
}
.horizontal-bento-card.theme-crimson:hover {
    border-color: #dc2626;
    box-shadow: 0 10px 35px -10px rgba(220, 38, 38, 0.45);
}

.horizontal-bento-card.theme-neon {
    background-color: #fefae0;
    color: #1c1b1f;
    --accent: #facc15;
    --accent-rgb: 250, 204, 21;
    border-color: rgba(250, 204, 21, 0.15);
}
.horizontal-bento-card.theme-neon:hover {
    border-color: #facc15;
    box-shadow: 0 10px 35px -10px rgba(250, 204, 21, 0.45);
}

.horizontal-bento-card:hover {
    transform: translateY(-4px) scale(1.015);
}

.card-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 1rem;
    background-color: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
    margin-right: 1.25rem;
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.horizontal-bento-card:hover .card-icon-wrapper {
    background-color: var(--accent);
    color: var(--bg);
    transform: scale(1.08) rotate(-4deg);
}

.card-content-wrapper {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}

.card-tag {
    font-family: var(--font-geist-mono), monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.2rem;
    font-weight: 700;
}

.card-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
}

.card-desc {
    font-size: 0.85rem;
    opacity: 0.75;
    line-height: 1.35;
    margin-bottom: 0;
}

.card-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 1rem;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-12px);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
}

.horizontal-bento-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
}

/* 🧱 Masonry Grid for Photography */
.masonry-grid {
    column-count: 1;
    column-gap: 1.5rem;
    width: 100%;
}

@media (min-width: 640px) {
    .masonry-grid {
        column-count: 2;
    }
}

@media (min-width: 1024px) {
    .masonry-grid {
        column-count: 3;
    }
}

.masonry-item {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    display: inline-block;
    width: 100%;
}

/* 💻 Interactive Terminal for About Page */
.terminal-window {
    background-color: #0f0f11;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.25rem;
    font-family: var(--font-geist-mono), Courier, monospace;
    font-size: 0.85rem;
    color: #a9b1d6;
    box-shadow: 0 10px 40px -15px rgba(0, 0, 0, 0.6);
    overflow: hidden;
}

.terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.50rem;
}

.terminal-dots {
    display: flex;
    gap: 6px;
}

.terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
}

.terminal-dot.red { background-color: #ff5f56; }
.terminal-dot.yellow { background-color: #ffbd2e; }
.terminal-dot.green { background-color: #27c93f; }

.terminal-title {
    font-size: 0.75rem;
    opacity: 0.5;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.terminal-body {
    max-height: 350px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.terminal-prompt {
    color: #4dfa7e;
    font-weight: 700;
}

.terminal-input-wrapper {
    display: flex;
    align-items: center;
}

.terminal-input {
    background: transparent;
    border: none;
    outline: none;
    color: #e0af68;
    flex-grow: 1;
    font-family: inherit;
    font-size: inherit;
    padding-left: 8px;
}

.terminal-output {
    white-space: pre-wrap;
    line-height: 1.5;
}

/* 🎨 Inverted Theme Card styles (Opposite Theme Font Color) */
.inverted-theme-card {
    background-color: var(--text) !important;
    color: var(--bg) !important;
    border: 1.5px solid rgba(var(--accent-rgb), 0.2);
    box-shadow: 0 4px 25px rgba(0, 0, 0, 0.03);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.inverted-theme-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px -10px rgba(var(--accent-rgb), 0.35);
}

.inverted-theme-card h2,
.inverted-theme-card h3,
.inverted-theme-card h4,
.inverted-theme-card span.specific {
    color: var(--bg) !important;
}

.inverted-theme-card p,
.inverted-theme-card div,
.inverted-theme-card li,
.inverted-theme-card a {
    color: var(--bg) !important;
}

.inverted-theme-card .inverted-tag {
    background-color: var(--bg) !important;
    color: var(--text) !important;
    border: 1px solid rgba(var(--accent-rgb), 0.1);
    transition: all 0.25s ease;
}

.inverted-theme-card .inverted-tag:hover {
    background-color: var(--accent) !important;
    color: var(--bg) !important;
    border-color: var(--accent) !important;
}